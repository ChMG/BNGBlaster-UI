{
  "id": null,
  "uid": "bngblaster-standard",
  "title": "BNGBlaster Standard Metrics",
  "tags": ["bngblaster", "prometheus", "standard"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "style": "dark",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "label": "Job",
        "datasource": "Prometheus",
        "query": "label_values(up, job)",
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "bngblaster-controller",
          "value": "bngblaster-controller"
        }
      },
      {
        "name": "instance",
        "type": "query",
        "label": "Target",
        "datasource": "Prometheus",
        "query": "label_values(up{job=\"$job\"}, instance)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "metric",
        "type": "query",
        "label": "Metric",
        "datasource": "Prometheus",
        "query": "label_values({job=\"$job\", __name__!~\"up|scrape_.*|go_.*|process_.*|promhttp_.*|python_.*\"}, __name__)",
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Targets Up",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(up{job=\"$job\",instance=~\"$instance\"})"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Availability",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * avg(up{job=\"$job\",instance=~\"$instance\"})"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Instances Running",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(instances_running{job=\"$job\",instance=~\"$instance\"}) or vector(0)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Instances Total",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(instances_total{job=\"$job\",instance=~\"$instance\"}) or vector(0)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Instances Overview",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(instances_running{job=\"$job\",instance=~\"$instance\"})",
          "legendFormat": "running"
        },
        {
          "refId": "B",
          "expr": "max(instances_total{job=\"$job\",instance=~\"$instance\"})",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Prometheus Scrape Duration",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "scrape_duration_seconds{job=\"$job\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Prometheus Samples Scraped",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "scrape_samples_scraped{job=\"$job\",instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Selected BNGBlaster Metric",
      "description": "Pick the metric from the top variable selector.",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{__name__=\"$metric\",job=\"$job\",instance=~\"$instance\"}",
          "legendFormat": "{{instance_name}} {{instance}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Available Metrics (Current)",
      "description": "Current metric names seen for the selected job/target.",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count by (__name__) ({job=\"$job\",instance=~\"$instance\"})",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
