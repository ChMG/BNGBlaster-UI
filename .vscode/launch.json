{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Flask UI (server.py)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/server.py",
      "args": [
        "8080"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "BNGBLASTER_URL": "http://localhost:8001,http://127.0.0.1:8001",
        "METRIC_GRAFANA_URL": "http://localhost:3000",
        "OIDC_ENABLED": "1",
        "OIDC_ISSUER_URL": "http://localhost:8090/realms/master",
        "OIDC_CLIENT_ID": "bngblaster-ui",
        "OIDC_CLIENT_SECRET": "W2kRFd0Tn2XlUpYItrWLIBA0TTXCy94N",
        "OIDC_SCOPES": "openid profile email",
        "OIDC_GROUPS_CLAIM": "groups",
        "OIDC_ALLOWED_GROUPS": "bngblaster-user",
        "OIDC_REDIRECT_URI": "http://localhost:8080/ui-api/auth/callback",
        "OIDC_POST_LOGOUT_REDIRECT_URI": "http://localhost:8080/",
        "APP_SECRET_KEY": "change-me-long-random-dev-secret"
      }
    },
    {
      "name": "Python: Gunicorn (single worker)",
      "type": "python",
      "request": "launch",
      "module": "gunicorn",
      "args": [
        "-w",
        "1",
        "-c",
        "${workspaceFolder}/gunicorn.conf.py",
        "server:app"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "BNGBLASTER_URL": "http://localhost:8001",
        "BIND": "0.0.0.0:8080",
        "METRIC_GRAFANA_URL": "http://localhost:3000",
        "OIDC_ENABLED": "1",
        "OIDC_ISSUER_URL": "http://localhost:8090/realms/master",
        "OIDC_CLIENT_ID": "bngblaster-ui",
        "OIDC_CLIENT_SECRET": "change-me",
        "OIDC_SCOPES": "openid profile email",
        "OIDC_GROUPS_CLAIM": "groups",
        "OIDC_ALLOWED_GROUPS": "bngblaster-user",
        "OIDC_REDIRECT_URI": "http://localhost:8080/ui-api/auth/callback",
        "OIDC_POST_LOGOUT_REDIRECT_URI": "http://localhost:8080/",
        "APP_SECRET_KEY": "change-me-long-random-dev-secret"
      }
    }
  ]
}
