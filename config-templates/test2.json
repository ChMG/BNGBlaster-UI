{
  "interfaces": {
    "a10nsp": [
      {
        "__comment__": "PPPoE Server",
        "interface": "$IF1:veth"
      }
    ],
    "access": [
      {
        "__comment__": "PPPoE Client 1",
        "interface": "$IF2",
        "type": "pppoe",
        "dhcp": true,
        "outer-vlan-min": 1,
        "outer-vlan-max": 100,
        "stream-group-id": 1,
        "a10nsp-interface": "$IF1"
      }
    ]
  },
  "pppoe": {
    "reconnect": true
  },
  "dhcp": {
    "enable": true
  },
  "dhcpv6": {
    "enable": false
  },
  "sessions": {
    "count": 50
  },
  "session-traffic": {
    "ipv4-pps": 1
  },
  "streams": [
    {
      "stream-group-id": 1,
      "name": "S1",
      "type": "ipv4",
      "direction": "both",
      "priority": 128,
      "length": 256,
      "pps": 1,
      "a10nsp-interface": "$IF1:veth"
    }
  ]
}